---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title="Blog" description="Essays and notes on intelligence, learning, and responsible AI.">
  <h1>Blog</h1>
  <p class="lede">Essays and notes — thinking out loud about intelligence, learning, and responsible AI.</p>

  {posts.length === 0 ? (
    <p style="color:var(--text-faint);">No posts yet. The first one is coming soon.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a class="post-title" href={`/blog/${post.slug}`}>{post.data.title}</a>
          <div class="post-meta">
            {fmt(post.data.date)}
            {post.data.tags.length > 0 && ' · '}
            {post.data.tags.map((t) => <span class="tag">{t}</span>)}
          </div>
          {post.data.description && <div class="post-desc">{post.data.description}</div>}
        </li>
      ))}
    </ul>
  )}
</Base>
